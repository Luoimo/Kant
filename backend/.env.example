# ==========================================
# Kant Reading Agent - 环境变量配置模板
# ==========================================

# ------------------------------------------
# 1. OpenAI (核心大模型配置，必须配置)
# ------------------------------------------
# 你的 OpenAI API Key（或者兼容 OpenAI 接口格式的其他大模型 Key，如 DeepSeek、通义千问等）
OPENAI_API_KEY="sk-你的_openai_api_key"
# 如果使用代理或国内的兼容大模型服务，请修改下面这个地址
# 例如 DeepSeek: https://api.deepseek.com/v1
# 例如 通义千问: https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_BASE_URL="https://api.openai.com/v1"

# 使用的模型名称
OPENAI_MODEL="gpt-4o-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# ------------------------------------------
# 2. AI 安全与防护 (LLMSecOps)
# ------------------------------------------
# Lakera Guard 安全网关配置 (可选，如果不配置则使用本地的正则过滤规则)
# 注册地址: https://platform.lakera.ai/
LAKERA_GUARD_API_KEY=""

# ------------------------------------------
# 3. 日志与可观测性监控 (LangSmith)
# ------------------------------------------
# 是否开启 LangSmith 监控？(填写 "true" 或 "false")
LANGCHAIN_TRACING_V2="false"
# 你的 LangSmith API Key
LANGCHAIN_API_KEY=""
# 监控项目名称
LANGCHAIN_PROJECT="Kant"
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"

# ------------------------------------------
# 4. 向量数据库 (Chroma)
# ------------------------------------------
# 如果留空，系统会自动使用本地 SQLite 存储向量。
# 如果想连接 Chroma Cloud，请填写以下配置：
CHROMA_API_KEY=""
CHROMA_TENANT="default_tenant"
CHROMA_DATABASE="default_database"

# ------------------------------------------
# 5. 其他本地存储配置 (通常不需要修改)
# ------------------------------------------
MEM0_USER_ID="kant-user"
CHROMA_PERSIST_DIR="data/chroma"
BOOKS_DATA_DIR="data/books"
NOTE_STORAGE_DIR="data/notes"
BOOKS_COLLECTION_NAME="kant_library"
BOOK_CATALOG_DB="data/books.db"
COVERS_DIR="data/covers"
POSTGRES_DSN=""
POSTGRES_HOST="localhost"
POSTGRES_PORT=5432
POSTGRES_USER="postgres"
POSTGRES_PASSWORD=""
POSTGRES_DATABASE="kant"
POSTGRES_CATALOG_SCHEMA="catalog"
NOTE_BACKEND="notion"
NOTION_API_KEY=""
NOTION_PARENT_PAGE_ID=""
JWT_SECRET_KEY="dev-change-me"
JWT_ISSUER="kant-backend"
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=30
REDIS_URL="redis://localhost:6379/0"

# ------------------------------------------
# 5.1 阿里云 OSS (对象存储)：EPUB 原文件 + 封面图片
# ------------------------------------------
# 留空则自动退回到本地文件系统 (BOOKS_DATA_DIR / COVERS_DIR)，便于本地开发
OSS_ACCESS_KEY_ID=""
OSS_SECRET_ACCESS_KEY=""
# 华北2(北京): oss-cn-beijing.aliyuncs.com
# 华东1(杭州): oss-cn-hangzhou.aliyuncs.com
OSS_ENDPOINT="oss-cn-beijing.aliyuncs.com"
OSS_BUCKET="kant"
OSS_BOOKS_PREFIX="books/"
OSS_COVERS_PREFIX="covers/"
# 签名 URL 有效期（秒），默认 1 小时
OSS_SIGNED_URL_EXPIRES=3600

# ------------------------------------------
# 6. 图数据库 (Neo4j，可选)
# ------------------------------------------
# 本地实例使用: bolt://localhost:7687
# Aura 远程实例使用: bolt+s://<instance-id>.databases.neo4j.io  （不要用 neo4j+s，会触发路由发现失败）
NEO4J_URI="neo4j+ssc://0155b603.databases.neo4j.io"
NEO4J_USER="0155b603"
NEO4J_PASSWORD="wtVFDS5oTaKKu8sZV7NoUQLKCuQyH0oZLpoD4w0Lchw"
NEO4J_DATABASE=""
# 知识图谱抽取后端：
# - llm:               gpt-4o-mini NER + RE
# - hanlp_ner_llm_re:  HanLP RESTful NER + LLM RE（使用 API Key，不下载本地模型）
GRAPH_EXTRACTOR_BACKEND="hanlp_ner_llm_re"
HANLP_API_URL="https://www.hanlp.com/hanlp/v21/redirect"
HANLP_API_KEY="69e9e04aeaf61a3aca91b90f"
HANLP_LANGUAGE="zh"
HANLP_NER_TASK="ner/ontonotes"
