# ==========================================
# Kant Reading Agent - 环境变量配置模板
# ==========================================

# ------------------------------------------
# 1. OpenAI (核心大模型配置，必须配置)
# ------------------------------------------
# 你的 OpenAI API Key（或者兼容 OpenAI 接口格式的其他大模型 Key，如 DeepSeek、通义千问等）
OPENAI_API_KEY="sk-你的_openai_api_key"

# 如果使用代理或国内的兼容大模型服务，请修改下面这个地址
# 例如 DeepSeek: https://api.deepseek.com/v1
# 例如 通义千问: https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_BASE_URL="https://api.openai.com/v1"

# 使用的模型名称
OPENAI_MODEL="gpt-4o-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# ------------------------------------------
# 2. AI 安全与防护 (LLMSecOps)
# ------------------------------------------
# Lakera Guard 安全网关配置 (可选，如果不配置则使用本地的正则过滤规则)
# 注册地址: https://platform.lakera.ai/
LAKERA_GUARD_API_KEY=""

# ------------------------------------------
# 3. 日志与可观测性监控 (LangSmith)
# ------------------------------------------
# 是否开启 LangSmith 监控？(填写 "true" 或 "false")
LANGCHAIN_TRACING_V2="false"
# 你的 LangSmith API Key
LANGCHAIN_API_KEY=""
# 监控项目名称
LANGCHAIN_PROJECT="Kant"
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"

# ------------------------------------------
# 4. 向量数据库 (Chroma)
# ------------------------------------------
# 如果留空，系统会自动使用本地 SQLite 存储向量。
# 如果想连接 Chroma Cloud，请填写以下配置：
CHROMA_API_KEY=""
CHROMA_TENANT="default_tenant"
CHROMA_DATABASE="default_database"

# ------------------------------------------
# 4.1 Obsidian 笔记知识库配置 (可选)
# ------------------------------------------
# 你的 Obsidian Vault 名称（若留空则使用当前默认或路径解析）
OBSIDIAN_VAULT=""

# ------------------------------------------
# 5. 其他本地存储配置 (通常不需要修改)
# ------------------------------------------
MEM0_USER_ID="kant-user"
CHROMA_PERSIST_DIR="data/chroma"
BOOKS_DATA_DIR="data/books"
NOTE_STORAGE_DIR="data/notes"
BOOKS_COLLECTION_NAME="kant_library"
BOOK_CATALOG_DB="data/books.db"
COVERS_DIR="data/covers"